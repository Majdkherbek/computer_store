<file path="public/style.css">
/* إعادة ضبط بسيطة */
*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* تنسيق الصفحة */
body{
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    height: 100vh;
}

/* شريط الأدوات */
.toolbar{
    background: #222;
    padding: 15px;

    display: flex;
    justify-content: center;
    gap: 12px;
}

/* الأزرار */
.toolbar button{
    background: #3498db;
    color: white;

    border: none;
    border-radius: 6px;

    padding: 10px 18px;

    font-size: 16px;
    cursor: pointer;

    transition: 0.3s;
}

/* تأثير عند المرور */
.toolbar button:hover{
    background: #217dbb;
    transform: scale(1.05);
}

/* القسم الأوسط */
.hero-section{
    height: calc(100vh - 80px);

    display: flex;
    flex-direction: column;

    justify-content: center;
    align-items: center;

    text-align: center;
}

/* العنوان الرئيسي */
.main-title{
    font-size: 55px;
    color: #222;

    margin-bottom: 15px;

    font-weight: bold;
}

/* النص الفرعي */
.sub-title{
    font-size: 24px;
    color: gold;

    font-weight: bold;
}

/* روابط التواصل */
.social-links{
    margin-top: 25px;

    display: flex;
    gap: 20px;
}

/* أزرار الروابط */
.social-links a{
    text-decoration: none;

    background: #222;
    color: white;

    padding: 12px 20px;

    border-radius: 8px;

    transition: 0.3s;
}

/* تأثير عند المرور */
.social-links a:hover{
    background: #3498db;

    transform: scale(1.05);
}

/* قسم الفورم */
.form-section{
    height: 100vh;

    display: flex;
    justify-content: center;
    align-items: center;
}

/* تصميم الفورم */
.computer-form{
    background: white;

    width: 400px;

    padding: 30px;

    border-radius: 12px;

    box-shadow: 0 0 15px rgba(0,0,0,0.1);
}

/* عنوان الفورم */
.form-title{
    text-align: center;

    margin-bottom: 25px;

    color: #222;
}

/* مجموعة الحقول */
.input-group{
    margin-bottom: 18px;

    display: flex;
    flex-direction: column;
}

/* العناوين */
.input-group label{
    margin-bottom: 8px;

    font-weight: bold;
}

/* الحقول */
.input-group input{
    padding: 12px;

    border: 1px solid #ccc;

    border-radius: 6px;

    font-size: 15px;
}

/* الأزرار */
.form-buttons{
    display: flex;

    justify-content: space-between;

    margin-top: 20px;
}

/* زر الإرسال */
.send-btn{
    background: #3498db;

    color: white;

    border: none;

    padding: 12px 18px;

    border-radius: 6px;

    cursor: pointer;
}

/* زر reset */
.reset-btn{
    background: #e74c3c;

    color: white;

    border: none;

    padding: 12px 18px;

    border-radius: 6px;

    cursor: pointer;
}

/* تأثير hover */
.send-btn:hover{
    background: #217dbb;
}

.reset-btn:hover{
    background: #c0392b;
}
/* صفحة الحواسيب */

.computers-section{
    padding: 40px;
}

/* عنوان الصفحة */

.computers-title{
    text-align: center;

    margin-bottom: 30px;

    font-size: 40px;

    color: #222;
}

/* الحاوية */

.computers-container{
    display: grid;

    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));

    gap: 20px;
}

/* كرت الحاسوب */

.computer-card{
    background: white;

    padding: 20px;

    border-radius: 12px;

    box-shadow: 0 0 10px rgba(0,0,0,0.1);

    transition: 0.3s;
}

/* تأثير hover */

.computer-card:hover{
    transform: translateY(-5px);
}

/* عنوان الكرت */

.computer-card h2{
    margin-bottom: 15px;

    color: #3498db;
}

/* النصوص */

.computer-card p{
    margin-bottom: 10px;

    font-size: 18px;
}
